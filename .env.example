# Environment Variables for Company Brain OS

# --- Company ---
COMPANY_NAME=Demo Company

# --- Data & Database ---
# Directory where raw files, generated wiki, and the SQLite DB live.
# Everything lives under this one root so a workspace can be backed up by
# copying a single folder.
DATA_DIR=./data
# Optional explicit override for the SQLite database file.
# If unset, the DB is stored at <DATA_DIR>/brain.db
# DB_PATH=./data/brain.db

# --- LLM (OpenAI-compatible) ---
# MVP provider strategy: a single OpenAI-compatible client.
# Works with OpenAI, OpenRouter, local gateways, Ollama's /v1 endpoint,
# and Bedrock-compatible proxies. Direct Anthropic Messages API support is
# not yet implemented (see docs/provider-setup.md).
LLM_PROVIDER=openai-compatible
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
# Optional custom base URL (OpenAI-compatible). Leave empty for OpenAI.
LLM_BASE_URL=

# Optional separate model for cheaper, high-volume tasks
# (chunk extraction, classification, metadata). Falls back to LLM_MODEL.
EXTRACTION_MODEL=
# Optional stronger model for synthesis, normalization, complex answers.
ANSWER_MODEL=
COMPILATION_MODEL=

# --- Embeddings (OpenAI-compatible) ---
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# --- Ingestion / chunking limits ---
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_UPLOAD=10
MAX_CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- Runtime ---
# Set to "false" in production to disable the demo seed route.
ENABLE_SEED_ROUTE=false
NEXT_PUBLIC_ENABLE_SEED_ROUTE=false
# Show retrieval diagnostics (retrieved pages, chunks, scores, rejections).
DEBUG_RETRIEVAL=false
NODE_ENV=development
